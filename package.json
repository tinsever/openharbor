{
  "name": "openharbor",
  "version": "0.0.1",
  "private": true,
  "description": "Harbor — safe execution layer for AI code agents",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "validate:capability-packs": "pnpm --filter @openharbor/host run validate:packs",
    "demo": "pnpm --filter @openharbor/demo start",
    "harbor": "pnpm --filter @openharbor/harbor-cli harbor"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
